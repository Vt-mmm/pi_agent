{
  "schemaVersion": 1,
  "projectId": "pi-company-platform",
  "displayName": "Pi Company Platform",
  "mode": "platform-development",
  "rootMarkers": [
    "AGENTS.md",
    "package.json"
  ],
  "protectedPaths": [
    ".git/**",
    "**/auth.json",
    "**/.env",
    "**/.env.*"
  ],
  "requiredContext": [
    "AGENTS.md",
    ".pi/project-context.md",
    "docs/architecture.md",
    "docs/project-adapters.md",
    "docs/mcp-and-tools.md"
  ],
  "taskModes": {
    "readOnly": {
      "tools": [
        "read",
        "grep",
        "find",
        "ls"
      ]
    },
    "sourceWrite": {
      "requiresPlan": true,
      "requiresVerify": true
    }
  },
  "verifyCommands": {
    "docsOnly": [
      "bash scripts/verify-local.sh"
    ],
    "source": [
      "bash scripts/verify-local.sh"
    ]
  },
  "mcpCapabilities": [
    "filesystem-readonly",
    "filesystem-write",
    "shell",
    "github",
    "browser",
    "memory"
  ],
  "capabilityPacks": [
    {
      "name": "engineering-base",
      "version": "0.1.0"
    }
  ],
  "capabilityPolicy": {
    "allowedOwners": [
      "platform-maintainers"
    ],
    "allowedLifecycles": [
      "experimental"
    ],
    "allowedFilesystemRead": [
      "**/*"
    ],
    "allowedFilesystemWrite": [
      "**/*"
    ],
    "allowedNetworkDomains": [],
    "allowedExternalActions": []
  },
  "memory": {
    "enabled": true,
    "mode": "manual",
    "scope": "project",
    "summaryFile": ".pi/memory/memory_summary.md",
    "handbookFile": ".pi/memory/MEMORY.md",
    "localDir": ".pi/memory/local",
    "readBeforeTask": true,
    "writePolicy": "explicit-only",
    "maxInjectedChars": 4000,
    "externalPackages": []
  },
  "runtimePolicy": {
    "execPolicy": "enforce",
    "contextBudget": "enforce",
    "toolRegistry": "advisory",
    "finalGate": "enforce"
  }
}
