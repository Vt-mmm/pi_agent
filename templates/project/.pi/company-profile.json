{
  "schemaVersion": 1,
  "projectId": "replace-me",
  "displayName": "Replace Me",
  "mode": "generic",
  "rootMarkers": [
    "AGENTS.md",
    "README.md"
  ],
  "protectedPaths": [
    ".git/**",
    "**/auth.json",
    "**/.env",
    "**/.env.*"
  ],
  "requiredContext": [
    "AGENTS.md",
    ".pi/project-context.md",
    "README.md"
  ],
  "verifyCommands": {
    "docsOnly": [
      "test -s README.md"
    ],
    "source": [
      "echo 'Configure verify command in .pi/company-profile.json'"
    ]
  },
  "mcpCapabilities": [
    "filesystem-readonly",
    "filesystem-write",
    "shell",
    "memory"
  ],
  "capabilityPacks": [
    {
      "name": "engineering-base",
      "version": "0.1.0"
    }
  ],
  "capabilityPolicy": {
    "allowedOwners": [
      "platform-maintainers"
    ],
    "allowedLifecycles": [
      "experimental"
    ],
    "allowedFilesystemRead": [
      "**/*"
    ],
    "allowedFilesystemWrite": [
      "**/*"
    ],
    "allowedNetworkDomains": [],
    "allowedExternalActions": []
  },
  "memory": {
    "enabled": true,
    "mode": "manual",
    "scope": "project",
    "summaryFile": ".pi/memory/memory_summary.md",
    "handbookFile": ".pi/memory/MEMORY.md",
    "localDir": ".pi/memory/local",
    "readBeforeTask": true,
    "writePolicy": "explicit-only",
    "maxInjectedChars": 4000,
    "externalPackages": []
  },
  "runtimePolicy": {
    "execPolicy": "enforce",
    "contextBudget": "enforce",
    "toolRegistry": "advisory",
    "finalGate": "enforce"
  }
}
