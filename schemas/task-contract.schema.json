{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vt-mmm/pi_agent/schemas/task-contract.schema.json",
  "title": "Pi Company Task Implementation Contract",
  "type": "object",
  "required": [
    "taskId",
    "summary",
    "riskLane",
    "expectedOutput",
    "acceptanceCriteria",
    "scope",
    "outOfScope",
    "protectedPaths",
    "requiredContext",
    "contextManifest",
    "verifyCommands",
    "changedFiles",
    "verifyEvidence",
    "trace"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "riskLane": {
      "enum": [
        "tiny",
        "normal",
        "high-risk"
      ]
    },
    "expectedOutput": {
      "type": "string",
      "minLength": 10
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "outOfScope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "protectedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredContext": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contextManifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "mcpCapabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verifyCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verifyEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "exitCode",
          "summary"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "exitCode": {
            "type": "integer"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "trace": {
      "type": "object",
      "required": [
        "outcome"
      ],
      "properties": {
        "outcome": {
          "enum": [
            "pending",
            "completed",
            "blocked",
            "partial",
            "failed"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
