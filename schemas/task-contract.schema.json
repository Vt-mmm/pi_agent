{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vt-mmm/pi_agent/schemas/task-contract.schema.json",
  "title": "Pi Company Task Implementation Contract",
  "type": "object",
  "required": [
    "taskId",
    "summary",
    "riskLane",
    "expectedOutput",
    "acceptanceCriteria",
    "scope",
    "outOfScope",
    "protectedPaths",
    "requiredContext",
    "contextManifest",
    "memoryCitations",
    "verifyCommands",
    "changedFiles",
    "verifyEvidence",
    "trace"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "riskLane": {
      "enum": [
        "tiny",
        "normal",
        "high-risk"
      ]
    },
    "expectedOutput": {
      "type": "string",
      "minLength": 10
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "outOfScope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "protectedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredContext": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contextManifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "memoryCitations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "mcpCapabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verifyCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "workPlan": {
      "type": "array",
      "description": "Optional solo-first task tree for parent/subagent coordination.",
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "role",
          "mode",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "role": {
            "enum": [
              "parent",
              "company-scout",
              "company-planner",
              "company-worker",
              "company-reviewer",
              "company-oracle"
            ]
          },
          "mode": {
            "enum": [
              "read-only",
              "single-writer",
              "review"
            ]
          },
          "status": {
            "enum": [
              "pending",
              "in-progress",
              "done",
              "skipped"
            ]
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            }
          }
        },
        "additionalProperties": false
      }
    },
    "reviewLenses": {
      "type": "array",
      "description": "Explicit review lenses for the task, used instead of blanket swarm review.",
      "uniqueItems": true,
      "items": {
        "enum": [
          "correctness",
          "tests",
          "scope",
          "security",
          "docs",
          "release",
          "package"
        ]
      }
    },
    "orchestration": {
      "type": "object",
      "description": "Resolved solo-first orchestration policy captured when the task starts.",
      "properties": {
        "mode": {
          "enum": [
            "solo-first",
            "bounded-subagents",
            "parallel-readonly"
          ]
        },
        "subagents": {
          "enum": [
            "not-used",
            "optional",
            "used"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "fieldGuidePath": {
          "type": "string",
          "minLength": 1
        },
        "modelRoles": {
          "type": "object",
          "properties": {
            "planner": { "type": "string" },
            "worker": { "type": "string" },
            "reviewer": { "type": "string" },
            "watchdog": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verifyEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "exitCode",
          "summary"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "exitCode": {
            "type": "integer"
          },
          "summary": {
            "type": "string"
          },
          "observed": {
            "type": "boolean",
            "description": "True only when the verify command was matched against an observed bash tool_result after task start."
          },
          "observedAt": {
            "type": "string",
            "description": "Timestamp of the matching bash tool_result observation."
          },
          "isError": {
            "type": "boolean",
            "description": "Observed Pi tool_result isError flag."
          },
          "matchedProfileCommand": {
            "type": "boolean",
            "description": "True only when the observed verify command exactly matches one of task.verifyCommands."
          }
        },
        "additionalProperties": true
      }
    },
    "trace": {
      "type": "object",
      "required": [
        "outcome"
      ],
      "properties": {
        "outcome": {
          "enum": [
            "pending",
            "completed",
            "blocked",
            "partial",
            "failed"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
