{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vt-mmm/pi_agent/schemas/project-profile.schema.json",
  "title": "Pi Company Project Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectId",
    "displayName",
    "mode",
    "rootMarkers",
    "protectedPaths",
    "requiredContext",
    "verifyCommands",
    "mcpCapabilities"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "permissionProfile": {
      "description": "Runtime permission profile. workspace-write is the default; trusted-full-access still keeps Company protected-path and destructive/external confirmation gates.",
      "enum": [
        "read-only",
        "workspace-write",
        "trusted-full-access"
      ]
    },
    "rootMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "protectedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "shellProtectedPaths": {
      "type": "array",
      "description": "Optional bash-specific protected path globs. These block shell access only, not path-tool read/write. If omitted, project protectedPaths also apply to bash path extraction. If provided for legacy profiles, keep write-sensitive paths in protectedPaths or readOnlyPaths as well.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "readOnlyPaths": {
      "type": "array",
      "description": "Paths that may be inspected with read/grep/find/ls but must not be modified; shell access is blocked automatically for these paths.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredContext": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "taskModes": {
      "type": "object"
    },
    "verifyCommands": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1
      }
    },
    "mcpCapabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capabilityPacks": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
          }
        }
      }
    },
    "capabilityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedOwners",
        "allowedLifecycles",
        "allowedFilesystemRead",
        "allowedFilesystemWrite",
        "allowedNetworkDomains",
        "allowedExternalActions"
      ],
      "properties": {
        "allowedOwners": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
          }
        },
        "allowedLifecycles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "experimental",
              "stable",
              "deprecated"
            ]
          }
        },
        "allowedFilesystemRead": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "allowedFilesystemWrite": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "allowedNetworkDomains": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?:\\*\\.)?[a-z0-9](?:[a-z0-9.-]{0,251}[a-z0-9])?$"
          }
        },
        "allowedExternalActions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "git-push",
              "github-pull-request",
              "github-issue",
              "release",
              "publish",
              "deploy",
              "database-change",
              "external-provider-write"
            ]
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "enum": [
            "off",
            "manual",
            "assisted",
            "external-package"
          ]
        },
        "scope": {
          "enum": [
            "project",
            "global",
            "hybrid"
          ]
        },
        "summaryFile": {
          "type": "string",
          "minLength": 1
        },
        "handbookFile": {
          "type": "string",
          "minLength": 1
        },
        "localDir": {
          "type": "string",
          "minLength": 1
        },
        "readBeforeTask": {
          "type": "boolean"
        },
        "writePolicy": {
          "enum": [
            "explicit-only",
            "task-trace",
            "session-summary"
          ]
        },
        "maxInjectedChars": {
          "type": "integer",
          "minimum": 0
        },
        "externalPackages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "orchestration": {
      "type": "object",
      "description": "Solo-first orchestration policy for subagent usage, review lenses, model-role guidance, and Field Guide memory.",
      "properties": {
        "defaultMode": {
          "enum": [
            "solo-first",
            "bounded-subagents",
            "parallel-readonly"
          ]
        },
        "maxConcurrentSubagents": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "defaultReviewLenses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "correctness",
              "tests",
              "scope",
              "security",
              "docs",
              "release",
              "package"
            ]
          }
        },
        "roleModelGuidance": {
          "type": "object",
          "properties": {
            "planner": { "type": "string", "minLength": 1 },
            "worker": { "type": "string", "minLength": 1 },
            "reviewer": { "type": "string", "minLength": 1 },
            "watchdog": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "fieldGuide": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "maxLines": {
              "type": "integer",
              "minimum": 0,
              "maximum": 200
            },
            "writePolicy": {
              "enum": [
                "explicit-only",
                "approved-workflow"
              ]
            },
            "readBeforeTask": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "techStack": {
      "type": "object",
      "description": "Selected project tech stack, stored as a Context7-ready manifest and concise per-tech snapshots.",
      "properties": {
        "provider": {
          "enum": [
            "context7"
          ]
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        },
        "contextDir": {
          "type": "string",
          "minLength": 1
        },
        "updatedAt": {
          "type": "string",
          "minLength": 1
        },
        "roles": {
          "type": "object",
          "properties": {
            "frontend": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "backend": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "database": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "mobile": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "devops": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "data": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "docs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "runtime": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "runtimePolicy": {
      "type": "object",
      "properties": {
        "execPolicy": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        },
        "contextBudget": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        },
        "toolRegistry": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        },
        "finalGate": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
