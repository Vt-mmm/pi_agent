{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vt-mmm/pi_agent/schemas/project-profile.schema.json",
  "title": "Pi Company Project Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectId",
    "displayName",
    "mode",
    "rootMarkers",
    "protectedPaths",
    "requiredContext",
    "verifyCommands",
    "mcpCapabilities"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "rootMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "protectedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "shellProtectedPaths": {
      "type": "array",
      "description": "Optional bash-specific protected path globs. If omitted, project protectedPaths also apply to bash path extraction.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredContext": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "taskModes": {
      "type": "object"
    },
    "verifyCommands": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1
      }
    },
    "mcpCapabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "enum": [
            "off",
            "manual",
            "assisted",
            "external-package"
          ]
        },
        "scope": {
          "enum": [
            "project",
            "global",
            "hybrid"
          ]
        },
        "summaryFile": {
          "type": "string",
          "minLength": 1
        },
        "handbookFile": {
          "type": "string",
          "minLength": 1
        },
        "localDir": {
          "type": "string",
          "minLength": 1
        },
        "readBeforeTask": {
          "type": "boolean"
        },
        "writePolicy": {
          "enum": [
            "explicit-only",
            "task-trace",
            "session-summary"
          ]
        },
        "maxInjectedChars": {
          "type": "integer",
          "minimum": 0
        },
        "externalPackages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "runtimePolicy": {
      "type": "object",
      "properties": {
        "execPolicy": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        },
        "contextBudget": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        },
        "toolRegistry": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        },
        "finalGate": {
          "enum": [
            "off",
            "advisory",
            "enforce"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
