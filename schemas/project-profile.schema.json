{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vt-mmm/pi_agent/schemas/project-profile.schema.json",
  "title": "Pi Company Project Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectId",
    "displayName",
    "mode",
    "rootMarkers",
    "protectedPaths",
    "requiredContext",
    "verifyCommands",
    "mcpCapabilities"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "rootMarkers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "protectedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredContext": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "taskModes": {
      "type": "object"
    },
    "verifyCommands": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1
      }
    },
    "mcpCapabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
