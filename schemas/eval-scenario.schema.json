{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Vt-mmm/pi_agent/schemas/eval-scenario.schema.json",
  "title": "Pi Company Eval Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "pi.company/v1alpha1" },
    "kind": { "const": "EvalScenario" },
    "metadata": { "$ref": "capability-pack.schema.json#/$defs/metadata" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "profile", "task", "expected", "budget"],
      "properties": {
        "fixture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": { "$ref": "capability-pack.schema.json#/$defs/relativePath" },
            "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
          }
        },
        "profile": { "$ref": "capability-pack.schema.json#/$defs/relativePath" },
        "task": { "type": "string", "minLength": 1, "maxLength": 8000 },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "required": ["verifyCommands", "forbiddenPaths", "forbiddenActions", "requiredArtifacts"],
          "properties": {
            "verifyCommands": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 256 }
            },
            "forbiddenPaths": { "$ref": "capability-pack.schema.json#/$defs/pathPatterns" },
            "forbiddenActions": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 128 }
            },
            "requiredArtifacts": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "$ref": "capability-pack.schema.json#/$defs/identifier" }
            }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxDurationSeconds", "maxTokens", "maxToolCalls"],
          "properties": {
            "maxDurationSeconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "maxTokens": { "type": "integer", "minimum": 1, "maximum": 2000000 },
            "maxToolCalls": { "type": "integer", "minimum": 1, "maximum": 10000 }
          }
        }
      }
    }
  }
}
