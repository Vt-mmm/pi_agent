{
  "schemaVersion": 1,
  "projectId": "fullstack-project",
  "displayName": "Fullstack Project",
  "mode": "fullstack",
  "rootMarkers": [
    "AGENTS.md",
    "README.md",
    "package.json",
    "apps",
    "packages",
    "frontend",
    "backend"
  ],
  "protectedPaths": [
    ".git/**",
    "**/auth.json",
    "**/.env",
    "**/.env.*",
    "**/*.pem",
    "**/*.key",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**"
  ],
  "requiredContext": [
    "AGENTS.md",
    ".pi/project-context.md",
    "README.md",
    "package.json"
  ],
  "taskModes": {
    "readOnly": {
      "tools": [
        "read",
        "grep",
        "find",
        "ls"
      ]
    },
    "sourceWrite": {
      "requiresPlan": true,
      "requiresVerify": true
    },
    "crossBoundary": {
      "requiresPlan": true,
      "requiresVerify": true,
      "requiresTrace": true
    }
  },
  "verifyCommands": {
    "docsOnly": [
      "test -s README.md"
    ],
    "source": [
      "npm run type-check --if-present",
      "npm run lint --if-present",
      "npm test --if-present"
    ],
    "runtime": [
      "npm run test:e2e --if-present"
    ]
  },
  "mcpCapabilities": [
    "filesystem-readonly",
    "github",
    "browser",
    "database-readonly"
  ]
}
