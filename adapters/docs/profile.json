{
  "schemaVersion": 1,
  "projectId": "docs-project",
  "displayName": "Documentation Project",
  "mode": "docs",
  "rootMarkers": [
    "AGENTS.md",
    "README.md",
    "docs",
    "mkdocs.yml",
    "mint.json",
    "docusaurus.config.js"
  ],
  "protectedPaths": [
    ".git/**",
    "**/auth.json",
    "**/.env",
    "**/.env.*"
  ],
  "requiredContext": [
    "AGENTS.md",
    ".pi/project-context.md",
    "README.md"
  ],
  "taskModes": {
    "readOnly": {
      "tools": [
        "read",
        "grep",
        "find",
        "ls"
      ]
    },
    "sourceWrite": {
      "requiresPlan": true,
      "requiresVerify": true
    }
  },
  "verifyCommands": {
    "docsOnly": [
      "test -s README.md || test -d docs"
    ],
    "source": [
      "git diff --check",
      "if test -f package.json; then npm test --if-present; else echo 'No docs test command configured; update .pi/company-profile.json if needed'; fi"
    ]
  },
  "mcpCapabilities": [
    "filesystem-readonly",
    "github"
  ]
}
