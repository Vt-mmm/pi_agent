{
  "schemaVersion": 1,
  "projectId": "data-project",
  "displayName": "Data / ETL Project",
  "mode": "data",
  "rootMarkers": [
    "AGENTS.md",
    "README.md",
    "pyproject.toml",
    "dbt_project.yml",
    "dvc.yaml",
    "notebooks",
    "data"
  ],
  "protectedPaths": [
    ".git/**",
    "**/auth.json",
    "**/.env",
    "**/.env.*",
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "data/raw/**",
    "data/production/**",
    "**/*.parquet",
    "**/*.sqlite",
    "**/*.duckdb"
  ],
  "requiredContext": [
    "AGENTS.md",
    ".pi/project-context.md",
    "README.md"
  ],
  "taskModes": {
    "readOnly": {
      "tools": [
        "read",
        "grep",
        "find",
        "ls"
      ]
    },
    "sourceWrite": {
      "requiresPlan": true,
      "requiresVerify": true
    },
    "dataMutation": {
      "requiresPlan": true,
      "requiresVerify": true,
      "requiresHumanGate": true
    }
  },
  "verifyCommands": {
    "docsOnly": [
      "test -s README.md"
    ],
    "source": [
      "if test -f pyproject.toml && command -v uv >/dev/null 2>&1; then uv run pytest; elif test -f pyproject.toml; then python -m pytest; elif test -f dbt_project.yml && command -v dbt >/dev/null 2>&1; then dbt compile; else echo 'No data verify command configured; update .pi/company-profile.json'; fi"
    ]
  },
  "mcpCapabilities": [
    "filesystem-readonly",
    "github",
    "database-readonly",
    "memory"
  ],
  "memory": {
    "enabled": true,
    "mode": "manual",
    "scope": "project",
    "summaryFile": ".pi/memory/memory_summary.md",
    "handbookFile": ".pi/memory/MEMORY.md",
    "localDir": ".pi/memory/local",
    "readBeforeTask": true,
    "writePolicy": "explicit-only",
    "maxInjectedChars": 4000,
    "externalPackages": []
  }
}
