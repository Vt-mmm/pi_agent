{
  "name": "pi-agent-platform",
  "version": "0.3.4",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Reusable Pi agent platform, project adapters, MCP/tool policy, and coding workflow harness.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-prompt",
    "agent-harness"
  ],
  "bin": {
    "pi-company-setup": "scripts/setup.sh",
    "pi-company-install": "scripts/install-global.sh",
    "pi-company-init": "scripts/init-project.sh",
    "pi-company-doctor": "scripts/team-doctor.sh",
    "pi-company-benchmark": "scripts/parity-benchmark.sh",
    "pi-company-usage": "scripts/pi-session-stats.sh",
    "pi-company-models": "scripts/pi-model-catalog.sh"
  },
  "pi": {
    "extensions": [
      "packages/pi-company-core/extensions/**/*.ts"
    ],
    "skills": [
      "packages/pi-company-core/skills"
    ],
    "prompts": [
      "packages/pi-company-core/prompts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "verify": "bash scripts/verify-local.sh",
    "setup": "bash scripts/setup.sh",
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "install-global": "bash scripts/install-global.sh",
    "init-project": "bash scripts/init-project.sh",
    "doctor": "bash scripts/team-doctor.sh",
    "benchmark": "bash scripts/parity-benchmark.sh",
    "smoke": "bash scripts/runtime-policy-smoke.sh",
    "usage": "bash scripts/pi-session-stats.sh",
    "models": "bash scripts/pi-model-catalog.sh"
  },
  "engines": {
    "node": ">=20"
  }
}
