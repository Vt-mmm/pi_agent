{
  "name": "pi-agent-platform",
  "version": "0.4.8",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Reusable Pi agent platform, project adapters, MCP/tool policy, and coding workflow harness.",
  "homepage": "https://piagent.io.vn",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vt-mmm/pi_agent.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-prompt",
    "agent-harness"
  ],
  "files": [
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    ".gitattributes",
    "adapters/",
    "catalog/",
    "docs/",
    "docs-site/",
    "evals/",
    "packs/",
    "packages/pi-company-core/",
    "schemas/",
    "scripts/",
    "templates/",
    "types/"
  ],
  "bin": {
    "pi-company-setup": "scripts/pi-company-cli.mjs",
    "pi-company-install": "scripts/pi-company-cli.mjs",
    "pi-company-init": "scripts/pi-company-cli.mjs",
    "pi-company-doctor": "scripts/pi-company-cli.mjs",
    "pi-company-benchmark": "scripts/pi-company-cli.mjs",
    "pi-company-usage": "scripts/pi-company-cli.mjs",
    "pi-company-models": "scripts/pi-company-cli.mjs",
    "pi-company-model-scope": "scripts/pi-company-cli.mjs",
    "pi-company-mcp": "scripts/pi-company-cli.mjs",
    "pi-company-subagents": "scripts/pi-company-cli.mjs",
    "pi-company-capabilities": "scripts/pi-company-cli.mjs",
    "pi-company-auto": "scripts/pi-company-cli.mjs"
  },
  "pi": {
    "extensions": [
      "packages/pi-company-core/extensions/**/*.ts"
    ],
    "skills": [
      "packages/pi-company-core/skills"
    ],
    "prompts": [
      "packages/pi-company-core/prompts"
    ],
    "subagents": {
      "agents": [
        "packages/pi-company-core/subagents"
      ]
    }
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "typebox": "1.1.38"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^7.0.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "verify": "bash scripts/verify-local.sh",
    "test": "node --test tests/*.test.mjs",
    "test:policy": "node --test tests/policy-core.test.mjs",
    "typecheck": "tsc --noEmit",
    "setup": "bash scripts/setup.sh",
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "install-global": "bash scripts/install-global.sh",
    "init-project": "bash scripts/init-project.sh",
    "doctor": "bash scripts/team-doctor.sh",
    "benchmark": "bash scripts/quality-benchmark.sh",
    "benchmark:redaction": "node scripts/redaction-benchmark.mjs",
    "audit:runtime": "bash scripts/audit-runtime-host.sh",
    "release:identity": "node scripts/verify-release-identity.mjs",
    "vercel:preflight": "node scripts/verify-vercel-link.mjs",
    "smoke": "bash scripts/runtime-policy-smoke.sh",
    "usage": "bash scripts/pi-session-stats.sh",
    "auto": "bash scripts/pi-auto.sh",
    "models": "bash scripts/pi-model-catalog.sh",
    "model-scope": "bash scripts/configure-model-scope.sh",
    "mcp": "bash scripts/configure-mcp.sh",
    "subagents": "bash scripts/configure-subagents.sh",
    "capabilities:check": "node scripts/capability-catalog.mjs catalog --check",
    "capabilities:catalog": "node scripts/capability-catalog.mjs catalog --write",
    "capabilities:doctor": "node scripts/capability-catalog.mjs doctor"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
