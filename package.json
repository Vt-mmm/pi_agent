{
  "name": "pi-agent-platform",
  "version": "0.3.21",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Reusable Pi agent platform, project adapters, MCP/tool policy, and coding workflow harness.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-prompt",
    "agent-harness"
  ],
  "bin": {
    "pi-company-setup": "scripts/setup.sh",
    "pi-company-install": "scripts/install-global.sh",
    "pi-company-init": "scripts/init-project.sh",
    "pi-company-doctor": "scripts/team-doctor.sh",
    "pi-company-benchmark": "scripts/quality-benchmark.sh",
    "pi-company-usage": "scripts/pi-session-stats.sh",
    "pi-company-models": "scripts/pi-model-catalog.sh",
    "pi-company-model-scope": "scripts/configure-model-scope.sh",
    "pi-company-mcp": "scripts/configure-mcp.sh",
    "pi-company-subagents": "scripts/configure-subagents.sh"
  },
  "pi": {
    "extensions": [
      "packages/pi-company-core/extensions/**/*.ts"
    ],
    "skills": [
      "packages/pi-company-core/skills"
    ],
    "prompts": [
      "packages/pi-company-core/prompts"
    ],
    "subagents": {
      "agents": [
        "packages/pi-company-core/subagents"
      ]
    }
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "verify": "bash scripts/verify-local.sh",
    "test": "node --test tests/*.test.mjs",
    "test:policy": "node --test tests/policy-core.test.mjs",
    "typecheck": "tsc --noEmit",
    "setup": "bash scripts/setup.sh",
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "install-global": "bash scripts/install-global.sh",
    "init-project": "bash scripts/init-project.sh",
    "doctor": "bash scripts/team-doctor.sh",
    "benchmark": "bash scripts/quality-benchmark.sh",
    "smoke": "bash scripts/runtime-policy-smoke.sh",
    "usage": "bash scripts/pi-session-stats.sh",
    "models": "bash scripts/pi-model-catalog.sh",
    "model-scope": "bash scripts/configure-model-scope.sh",
    "mcp": "bash scripts/configure-mcp.sh",
    "subagents": "bash scripts/configure-subagents.sh"
  },
  "engines": {
    "node": ">=20"
  }
}
